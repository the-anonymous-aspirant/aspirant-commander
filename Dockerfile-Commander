FROM python:3.11-slim

# LibreOffice (core only — no GUI) is used to convert the Värdeutlåtande
# .docx to .pdf at download time. libreoffice-core alone adds roughly
# 350 MB to the image; the full libreoffice meta-package adds ~1 GB and
# is unnecessary for headless conversion.
RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        libreoffice-core \
        libreoffice-writer \
        fonts-dejavu \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY app/ ./app/

EXPOSE 8000

CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8000"]
